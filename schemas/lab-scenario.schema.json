{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-ready.ph/schemas/lab-scenario.schema.json",
  "title": "AI Ready PH Lab Scenario",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "slug",
    "version",
    "labSlug",
    "title",
    "summary",
    "audiences",
    "difficulty",
    "estimatedMinutes",
    "syntheticDataOnly",
    "brief",
    "tasks",
    "rubricVersion",
    "status"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 3 },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "version": { "type": "integer", "minimum": 1 },
    "labSlug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 5, "maxLength": 120 },
    "summary": { "type": "string", "minLength": 20, "maxLength": 400 },
    "audiences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["BEGINNER", "VIRTUAL_ASSISTANT", "FREELANCER", "BUSINESS_OWNER"]
      }
    },
    "difficulty": { "enum": ["FOUNDATION", "PRACTITIONER", "ADVANCED"] },
    "estimatedMinutes": { "type": "integer", "minimum": 5, "maximum": 180 },
    "syntheticDataOnly": { "const": true },
    "brief": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "goal", "constraints", "successCriteria"],
      "properties": {
        "role": { "type": "string", "minLength": 3 },
        "goal": { "type": "string", "minLength": 10 },
        "constraints": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3 }
        },
        "successCriteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3 }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "instruction", "required"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "instruction": { "type": "string", "minLength": 10 },
          "required": { "type": "boolean" }
        }
      }
    },
    "rubricVersion": { "type": "string", "minLength": 3 },
    "status": { "enum": ["DRAFT", "PUBLISHED", "RETIRED"] }
  }
}
